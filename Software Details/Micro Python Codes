import time
import math
from machine import Pin, I2C
from pca9685 import PCA9685

SERVOMIN = 225
SERVOMAX = 425
NUM_SERVOS = 8
TICK_MS    = 20
STEPS      = 30

DEG_MIN = 0
DEG_MAX = 50
DEG_MID = (DEG_MIN + DEG_MAX) / 2

PHASE = [
    0,              # ch0 hip
    math.pi,        # ch1 hip
    math.pi,        # ch2 hip
    0,              # ch3 hip
    -math.pi / 2,   # ch4 knee
    -math.pi / 2,   # ch5 knee  ← FIXED (was +pi/2)
    -math.pi / 2,   # ch6 knee  ← FIXED (was +pi/2)
    -math.pi / 2,   # ch7 knee
]

HIP_AMP  = 20
KNEE_AMP = 12

AMP = [
    HIP_AMP,
    HIP_AMP,
    HIP_AMP,
    HIP_AMP,
    KNEE_AMP,
    KNEE_AMP,
    KNEE_AMP,
    KNEE_AMP,
]

def deg_to_pwm(degrees: float) -> int:
    pwm = SERVOMIN + (degrees / 90.0) * (SERVOMAX - SERVOMIN)
    return max(SERVOMIN, min(SERVOMAX, int(pwm)))

i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=400_000)
pca = PCA9685(i2c)
pca.freq(50)

def set_servo(ch: int, pwm_val: int) -> None:
    pwm_val = max(SERVOMIN, min(SERVOMAX, int(pwm_val)))
    pca.duty(ch, pwm_val)

print("Zeroing all servos...")
for ch in range(NUM_SERVOS):
    set_servo(ch, deg_to_pwm(0))
time.sleep(2)

print("Moving to midpoint stance...")
for step in range(STEPS + 1):
    t = step / STEPS
    for ch in range(NUM_SERVOS):
        deg = t * DEG_MID
        set_servo(ch, deg_to_pwm(deg))
    time.sleep_ms(TICK_MS)
time.sleep(1)

print("Walk cycle starting...")
step = 0
while True:
    angle = (2 * math.pi * step) / STEPS
    for ch in range(NUM_SERVOS):
        deg = DEG_MID + AMP[ch] * math.sin(angle + PHASE[ch])
        deg = max(DEG_MIN, min(DEG_MAX, deg))
        set_servo(ch, deg_to_pwm(deg))
    time.sleep_ms(TICK_MS)
    step = (step + 1) % STEPS


