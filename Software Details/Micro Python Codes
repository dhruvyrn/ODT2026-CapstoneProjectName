import time
import math
from machine import Pin, I2C
from pca9685 import PCA9685

# ── Hardware ──────────────────────────────────────────────────
i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=400_000)
pca = PCA9685(i2c)
pca.freq(50)

# ── PWM limits ────────────────────────────────────────────────
SERVOMIN = 225
SERVOMAX = 425
NUM_SERVOS = 8
DEG_MIN = 0
DEG_MAX = 50
DEG_MID = 25.0

# ── Channel mapping ───────────────────────────────────────────
# ch0 = FR hip    ch4 = FR knee
# ch1 = FL hip    ch5 = FL knee
# ch2 = BL hip    ch6 = BL knee
# ch3 = BR hip    ch7 = BR knee

def deg_to_pwm(degrees):
    pwm = SERVOMIN + (degrees / 90.0) * (SERVOMAX - SERVOMIN)
    return max(SERVOMIN, min(SERVOMAX, int(pwm)))

def set_servo(ch, degrees):
    degrees = max(DEG_MIN, min(DEG_MAX, degrees))
    pca.duty(ch, deg_to_pwm(degrees))

def set_all(degrees):
    for ch in range(NUM_SERVOS):
        set_servo(ch, degrees)

# ── Smooth move one servo ─────────────────────────────────────
def smooth(ch, from_deg, to_deg, steps=20, tick_ms=18):
    """Move a single servo smoothly from one angle to another."""
    for s in range(steps + 1):
        t = s / steps
        deg = from_deg + t * (to_deg - from_deg)
        set_servo(ch, deg)
        time.sleep_ms(tick_ms)

# ── Stand still — all legs planted ───────────────────────────
def stand():
    set_all(DEG_MID)
    time.sleep_ms(500)

# ══════════════════════════════════════════════════════════════
# HELLO WAVE
# Uses the FR leg (ch0 = hip, ch4 = knee) as the "arm"
# 1. Lifts the FR knee up high (raises the arm)
# 2. Swings the FR hip left and right repeatedly (waving)
# 3. Lowers the leg back down when done
# All other 3 legs stay planted so robot stays balanced
# ══════════════════════════════════════════════════════════════

def hello_wave(waves=4):
    print("Hello!")

    # Step 1: stand still so robot is stable
    stand()
    time.sleep_ms(300)

    # Step 2: raise the FR leg (ch4 knee lifts UP, ch0 hip goes forward)
    print("Raising arm...")
    smooth(ch=4, from_deg=DEG_MID, to_deg=DEG_MAX, steps=25, tick_ms=15)  # knee up
    smooth(ch=0, from_deg=DEG_MID, to_deg=40,       steps=20, tick_ms=15)  # hip forward
    time.sleep_ms(300)

    # Step 3: wave left and right
    print("Waving...")
    hip_left  = 15   # swing left
    hip_right = 42   # swing right

    for w in range(waves):
        # swing to the left
        smooth(ch=0, from_deg=40, to_deg=hip_left,  steps=15, tick_ms=12)
        time.sleep_ms(80)
        # swing to the right
        smooth(ch=0, from_deg=hip_left, to_deg=hip_right, steps=15, tick_ms=12)
        time.sleep_ms(80)

    # back to center after waving
    smooth(ch=0, from_deg=hip_right, to_deg=DEG_MID, steps=15, tick_ms=15)

    # Step 4: lower the leg back down gently
    print("Lowering arm...")
    smooth(ch=4, from_deg=DEG_MAX, to_deg=DEG_MID, steps=25, tick_ms=15)  # knee down
    time.sleep_ms(400)

    print("Done waving!")

